{
  "compilerOptions": {
    "tsBuildInfoFile": "./node_modules/.tmp/tsconfig.node.tsbuildinfo",

    "target": "ES2022",
    "lib": ["ESNext"],
    "module": "ESNext",

    /* REQUIRED for referenced tsconfig */
    "composite": true,
    "noEmit": false,

    /* Node compatibility */
    "moduleResolution": "Node",
    "types": ["node"],

    /* Vite config requires isolatedModules OFF */
    "isolatedModules": false
  },

  "include": ["vite.config.ts"]
}
